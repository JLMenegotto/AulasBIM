          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a6321c7e19e54de3834df7e6be8c01df",
          "Name": "di",
          "Description": "di",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "cd3c1a6fad564ed6981b2f28e3d1ebd8",
          "Name": "df",
          "Description": "df",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "aef2cf22a948441fb80a08d52ff04b60",
          "Name": "and",
          "Description": "and = [hf, 0, hi, ho, ho + 0.8, ho * 1.2]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "19fac2dc0a414ef89861caac74fb1a9a",
          "Name": "pa",
          "Description": "pa = \"Elevation\"",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ca6e03d9aabe4105b796be51a42b0aef",
          "Name": "nom",
          "Description": "nom = \"Cota\" + (DSCore.Math.Floor(and))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ba2429679dea4ea38ac0ed97b4b1daba",
          "Name": "i",
          "Description": "i = [2, 3, 4, 13, 19, 17, 15, 7]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "17c079357f954dd3bb3323255da9a52d",
          "Name": "lev",
          "Description": "lev = Revit.Elements.Level.ByElevationAndName(and, nom)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2d50f87d66d04e4cbc163ea34071cef4",
          "Name": "cot",
          "Description": "cot = lev.SetParameterByName(pa, and)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "33d2d1699000442b8ea0045062e4b663",
          "Name": "x",
          "Description": "x = ([-0.5 + k, 0, 0.5 + k]) * l",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "997ac3bcfcf7475787ecfd9b5afffdcb",
          "Name": "y",
          "Description": "y = ([0.5, c1, c2, 0, -c2, -c1, -0.5]) * p",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "8d155a0ec5c849d7a9480149c0364354",
          "Name": "LP",
          "Description": "LP = Autodesk.DesignScript.Geometry.Point.ByCoordinates(x<1>, y, 0)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "da853afd9c0b4fd08c8ee6f4a1c7bb5a",
          "Name": "LV",
          "Description": "LV = DesignScript.Builtin.Get.ValueAtIndex(List.Flatten(LP, 1), i)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e661b0319f114de79b822d53ba63109d",
          "Name": "PO",
          "Description": "PO = Autodesk.DesignScript.Geometry.PolyCurve.ByPoints(LV, 1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "8abf62e0543b42b29e1751ab47d963be",
          "Name": "Ei",
          "Description": "Ei = Autodesk.DesignScript.Geometry.Line.ByBestFitThroughPoints(LV)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "fa2ff9a118274a0db507788df41f3338",
          "Name": "mas",
          "Description": "mas = Mastro(mod, PO, cat, esc, des, hf, ho, hi, l)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2f9382931db1402baf1803b7c7b1b4dd",
          "Name": "Po1",
          "Description": "Po1 = DesignScript.Builtin.Get.ValueAtIndex(DesignScript.Builtin.Get.ValueAtIndex(mas, 0), 1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "336d41c643ec4d439eb1a005fc42be6b",
          "Name": "Po2",
          "Description": "Po2 = DesignScript.Builtin.Get.ValueAtIndex(DesignScript.Builtin.Get.ValueAtIndex(mas, 0), 2)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3db2c1f1e1f84d6b9ce2a67db084299a",
          "Name": "cab",
          "Description": "cab = Estais(Po1, Po2, di, df, hi, qes)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b5c5240a489e4367a639952827fdd8c8",
          "Name": "ptc",
          "Description": "ptc = List.Flatten(DesignScript.Builtin.Get.ValueAtIndex(cab, 3), 2)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ee1a1855a73440a6b2a7be2d340a2bf8",
          "Name": "function",
          "Description": "Pista(lt, ht, et, ptc)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "l;\np;\nho;\nhi;\nhf;\nc1;\nc2;\nk;\ne;\nan;\nesc;\ndes;\ncat;\nmod;\nqes;\nlt;\nht;\net;\ndi;\ndf;\nand = [hf, 0, hi, ho , ho+0.8, ho*1.20];\npa  = \"Elevation\";\nnom = \"Cota\"+Math.Floor(and);\ni   = [2,3,4,13,19,17,15,7];\nlev = Level.ByElevationAndName(and , nom );\ncot = lev.SetParameterByName  ( pa , and );\n//---------------------------------------\nx   = [-0.50+k ,   0    ,     0.5+k] * l;\ny   = [ 0.50,c1,c2,0,-c2,-c1,-0.5  ] * p;\n//---------------------------------------\nLP  = Point.ByCoordinates ( x<1>, y, 0 );\nLV  = List.Flatten        ( LP  , 1    )[i];\nPO  = PolyCurve.ByPoints  ( LV  , 1    );\nEi  = Line.ByBestFitThroughPoints( LV  );\n\nmas = Mastro (mod,PO,cat,esc,des,hf,ho,hi,l);\nPo1 = mas[0][1];\nPo2 = mas[0][2];\ncab = Estais (Po1, Po2, di, df, hi, qes);\nptc = List.Flatten(cab[3], 2);\nPista ( lt, ht , et , ptc );"
    },
