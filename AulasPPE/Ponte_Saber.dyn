    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "a30a279de5764b47afd8d73c4708b2d0",
      "NodeType": "CodeBlockNode",
      "Inputs": [],
      "Outputs": [],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "//------------------------------------------------------\n//  Harpa de estai\n//------------------------------------------------------\ndef Estais( p , q , n)\n{\n    p1 = PolyCurve.Points( p )[7];\n    p2 = PolyCurve.Points( q )[7];\n    p3 = Point.Translate ( p1 , di*2 , 0 , 0 );\n    p4 = Point.Translate ( p3 , di*5 , 0 , 0 );\n//------------------------------------------------------\n// Posicionamento do eixo dos cabos no mastro\n//------------------------------------------------------\n    ex  = Line.ByStartPointEndPoint ( p1 , p2 );\n    di  = ex.Length / 2.4;\n    ta  = ex.TangentAtParameter ( 0.0);\n    pm  = ex.PointAtParameter   ( 0.5);\n//------------------------------------------------------\n// Posicionamento da Harpa\n//------------------------------------------------------\n    ha1 = Line.ByStartPointDirectionLength ( pm,ta,di);\n    ha2 = Line.ByStartPointEndPoint        ( p3,p4   );\n    ph1 = Line.PointAtParameter(ha1 , 0..1..#n);\n    ph2 = Line.PointAtParameter(ha2 , 0..1..#n);\n    est = Line.ByStartPointEndPoint( ph1 , ph2);\n\n    return [ ha1, ha2 , ph1, ph2, est];\n};"
    },
