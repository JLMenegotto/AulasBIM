          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "75aa71debe2c4c4b9516cacea7e88318",
          "Name": "di",
          "Description": "di",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "38d3a79352c34044992e58a4d1e6b04b",
          "Name": "df",
          "Description": "df",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a5b69e5ddaac4990a6db7cfafff78d84",
          "Name": "i",
          "Description": "i = [2, 3, 4, 13, 19, 17, 15, 7]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "81c2a59650054d659560a72341aecd02",
          "Name": "cta",
          "Description": "cta = [hf, 0, hi, ho, ho + 0.8, ho * 1.2]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "936295a7ec504c32aae391c1ef0b1e0a",
          "Name": "par",
          "Description": "par = \"Elevation\"",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "6e6f89bcc9dd46beb493b741ad7b06e1",
          "Name": "nom",
          "Description": "nom = \"Cota \" + (DSCore.Math.Floor(cta))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "02d2fb41d79342ccb3ca326bf0852ed6",
          "Name": "lev",
          "Description": "lev = Revit.Elements.Level.ByElevationAndName(cta, nom)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d95e7cb275ec431687ed544516528cc7",
          "Name": "cot",
          "Description": "cot = lev.SetParameterByName(par, cta)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "916b185d84214dd791add28e3d6daacf",
          "Name": "x",
          "Description": "x = ([-0.5 + k, 0, 0.5 + k]) * l",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "4a69bbdda3464ca6b45e97dea18f73dc",
          "Name": "y",
          "Description": "y = ([0.5, r, s, 0, -s, -r, -0.5]) * p",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "53d6bc8f6a62484faa7c80fb0ecfd70b",
          "Name": "LiP",
          "Description": "LiP = Autodesk.DesignScript.Geometry.Point.ByCoordinates(x<1>, y, 0)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "563a1ab229a349f19daa47c62a63a99c",
          "Name": "LiV",
          "Description": "LiV = DesignScript.Builtin.Get.ValueAtIndex(List.Flatten(LiP, 1), i)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a9fec9bf1892403ea58f9aff39aed8ca",
          "Name": "Pol",
          "Description": "Pol = Autodesk.DesignScript.Geometry.PolyCurve.ByPoints(LiV, 1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "07203ea262ce450ea9bdf53dd5c8c7df",
          "Name": "Ine",
          "Description": "Ine = Autodesk.DesignScript.Geometry.Line.ByBestFitThroughPoints(LiV)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "8800514e6639446390336b7c6b0eea7d",
          "Name": "Po1",
          "Description": "Po1 = DesignScript.Builtin.Get.ValueAtIndex(DesignScript.Builtin.Get.ValueAtIndex(mas, 0), 1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b01469f4c20f4addaa7462e77059f23f",
          "Name": "Po2",
          "Description": "Po2 = DesignScript.Builtin.Get.ValueAtIndex(DesignScript.Builtin.Get.ValueAtIndex(mas, 0), 2)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e0cf07a894c24962979e7d09979275c2",
          "Name": "ptc",
          "Description": "ptc = List.Flatten(DesignScript.Builtin.Get.ValueAtIndex(cab, 3), 2)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "60dbd6bf4368475393db7cf0ccce771f",
          "Name": "mas",
          "Description": "mas = Mastro(Pol, cat, esc, des, hf, ho, hi, mod)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "dec0d649b4a54290b437a8c6e3d271a0",
          "Name": "cab",
          "Description": "cab = Estais(Po1, Po2, di, df, hi, qes)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2e0ca8d51ba544e4acbe18e508f27fea",
          "Name": "pis",
          "Description": "pis = Pista(lt, ht, et, ptc)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "l;\np;\nho;\nhi;\nhf;\nr;\ns;\nk;\ne;\nan;\nesc;\ndes;\ncat;\nmod;\nqes;\nlt;\nht;\net;\ndi;\ndf;\n//----------------------------------------------\ni   = [2,3,4,13,19,17,15,7];\ncta = [hf, 0, hi, ho , ho+0.8, ho*1.20];\npar = \"Elevation\";\nnom = \"Cota \"+Math.Floor(cta);\nlev = Level.ByElevationAndName(cta , nom );\ncot = lev.SetParameterByName  (par , cta );\n//----------------------------------------------\nx   = [-0.50+k,    0    , 0.5+k] * l;\ny   = [ 0.50,r,s,0,-s,-r,-0.5  ] * p;\n//----------------------------------------------\nLiP = Point.ByCoordinates ( x<1>, y, 0 );\nLiV = List.Flatten        ( LiP , 1    )[i];\nPol = PolyCurve.ByPoints  ( LiV , 1    );\nIne = Line.ByBestFitThroughPoints( LiV );\n//----------------------------------------------\nPo1 = mas[0][1];\nPo2 = mas[0][2];\nptc = List.Flatten(cab[3], 2);\nmas = Mastro ( Pol,cat,esc,des,hf,ho,hi, mod);\ncab = Estais ( Po1,Po2,di ,df ,hi,qes);\npis = Pista  ( lt, ht , et , ptc );"
    },
