    {
      "ConcreteType": "CoreNodeModels.Input.DoubleSlider, CoreNodeModels",
      "NumberType": "Double",
      "MaximumValue": 15.0,
      "MinimumValue": 5.0,
      "StepValue": 1.0,
      "Id": "b03ec87526e04b84acc49a0c52450f85",
      "NodeType": "NumberInputNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "48c75218d5b34994ba076a5a491f6697",
          "Name": "",
          "Description": "Double",
          "UsingDefaultValue": false,
